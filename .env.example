# Redis password (set the same value on all servers)
REDIS_PASSWORD=changeme

# Server B and C only: IP/hostname of Server A
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_here

# Chat worker - dedicated account for sending ingame chat messages
CHAT_ACCOUNT_USER=chataccount@example.com
CHAT_ACCOUNT_PWD=password
CHAT_CHANNEL_URL=sendbird_group_channel_XXXXXX_XXXXXXXX
