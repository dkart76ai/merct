# Redis password (set the same value on all servers)
REDIS_PASSWORD=changeme

# Server B and C only: IP/hostname of Server A
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Comma-separated list of workers for the API to monitor/wake
# Format: workerId|http://host:port
WORKER_URLS=worker-1|http://localhost:3001,worker-2|http://<server-b-ip>:3001,worker-3|http://<server-c-ip>:3001

# Worker accounts (use only the relevant one per server)
WORKER_1_USER=user+1@outlook.com
WORKER_1_PWD=passhere

WORKER_2_USER=user+2@outlook.com
WORKER_2_PWD=passhere

WORKER_3_USER=user+3@outlook.com
WORKER_3_PWD=passhere
